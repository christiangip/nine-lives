[gd_resource type="Environment" format=3]

; Dim interior environment for generated missions (world-gen Phase 1C). Low sky-ambient so ceilings
; actually create dark and the placed LightFixtures read as pools of light. Exterior read comes from the
; realizer's Sun; interiors rely on fixtures.

[sub_resource type="ProceduralSkyMaterial" id="ProceduralSkyMaterial_int"]
sky_horizon_color = Color(0.34, 0.35, 0.39, 1)
ground_horizon_color = Color(0.18, 0.18, 0.20, 1)

[sub_resource type="Sky" id="Sky_int"]
sky_material = SubResource("ProceduralSkyMaterial_int")

[resource]
background_mode = 2
sky = SubResource("Sky_int")
ambient_light_source = 3
ambient_light_energy = 0.18
tonemap_mode = 2
